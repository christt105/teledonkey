# --- Telegram ---------------------------------------------------------------
# Token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-your-token-here
# Comma/space separated Telegram user IDs allowed to use the bot (get yours
# from @userinfobot). Leave empty to allow everyone (NOT recommended).
ALLOWED_USER_IDS=123456789

# --- mldonkey ----------------------------------------------------------------
# Host where mldonkey's ports are published. From another container on the same
# server, use the server's LAN IP (the ports are published on the host).
MLDONKEY_HOST=192.168.1.15
# Host port mapped to mldonkey's telnet console (4002 -> 4000 in your compose).
MLDONKEY_TELNET_PORT=4002
# Console credentials. Defaults are usually admin / empty password.
MLDONKEY_USER=admin
MLDONKEY_PASSWORD=
